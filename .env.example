# Blinko — Railway Template Environment Variables

# --- Required ---
# PostgreSQL connection string (Railway auto-injects when you add a Postgres service)
DATABASE_URL=${{Postgres.DATABASE_URL}}

# Random secret for authentication encryption (generate: openssl rand -base64 32)
NEXTAUTH_SECRET=change-me-to-a-random-string

# Public URL of your deployed Blinko instance
NEXTAUTH_URL=https://your-app.up.railway.app

# --- Optional ---
# Port (default: 1111). Railway auto-injects PORT.
# PORT=1111
