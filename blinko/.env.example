[TEMPLATE]
# =============================================================================
# Blinko Service — Required Environment Variables
# =============================================================================
# The DATABASE_URL default below assumes the sibling `postgres` Railway
# service is running with these defaults (set in postgres/):
#   POSTGRES_USER=postgres
#   POSTGRES_PASSWORD=postgres
#   POSTGRES_DB=blinko
#
# If you rotate POSTGRES_PASSWORD on the postgres service, update the URL
# below to match — e.g.:
#   DATABASE_URL=postgresql://postgres:<NEW_PASSWORD>@postgres.railway.internal:5432/blinko
#
# NEXTAUTH_URL must start with `https://` (the `https://` prefix is mandatory:
# RAILWAY_PUBLIC_DOMAIN resolves to the bare domain only, and Blinko's auth
# callback requires a fully qualified URL).

# --- Required ---
DATABASE_URL=postgresql://postgres:postgres@postgres.railway.internal:5432/blinko
NEXTAUTH_SECRET=${{secret(64)}}
NEXTAUTH_URL=https://${{RAILWAY_PUBLIC_DOMAIN}}

# --- Optional ---
# PORT=1111   # Railway auto-injects PORT — uncomment only for local dev
